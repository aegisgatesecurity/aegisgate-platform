# AegisGate Platform Environment Variables Template
# Copy this file to .env and fill in your values

# =============================================================================
# Stripe Configuration (REQUIRED for billing)
# =============================================================================

# ⚠️ IMPORTANT: Replace these with your actual Stripe keys from:
# https://dashboard.stripe.com/apikeys
# DO NOT commit real keys - use environment variables in production!

# Stripe Publishable Key (safe for frontend)
STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_PUBLISHABLE_KEY_HERE

# Stripe Secret Key (server-side only, keep secure!)
STRIPE_SECRET_KEY=sk_live_YOUR_SECRET_KEY_HERE

# Stripe Webhook Secret - Get from: Stripe Dashboard → Developers → Webhooks → Copy signing secret
STRIPE_WEBHOOK_SECRET=whsec_CsCdMALXQRV5HPAcFhN4MalNrySigvDW

# =============================================================================
# Stripe Price IDs (from Stripe Dashboard → Products → Copy Price ID)
# =============================================================================

# Starter Subscription
STRIPE_PRICE_STARTER_MONTHLY=price_1TUpnpK2DQfk64XNQVQLqMRD
STRIPE_PRICE_STARTER_ANNUAL=price_1TUpnpK2DQfk64XNQVQLqMRD

# Developer Subscription
STRIPE_PRICE_DEVELOPER_MONTHLY=price_1TUponK2DQfk64XNe6WUb7NJ
STRIPE_PRICE_DEVELOPER_ANNUAL=price_1TUpwnK2DQfk64XNUJsYscrS

# Professional Subscription
STRIPE_PRICE_PROFESSIONAL_MONTHLY=price_1TUpw1K2DQfk64XNDsGRxKpv
STRIPE_PRICE_PROFESSIONAL_ANNUAL=price_1TUpw1K2DQfk64XNDsGRxKpv

# =============================================================================
# AegisGate Configuration
# =============================================================================

# License configuration
AEGISGATE_LICENSE_ENABLED=true
AEGISGATE_LICENSE_STRICT_MODE=true

# Tier defaults
AEGISGATE_TIER=community

# Port configuration
AEGISGATE_PORT=8080
AEGISGATE_METRICS_PORT=9090

# =============================================================================
# Security (optional)
# =============================================================================

# HMAC secret for A2A communication
AEGISGATE_A2A_HMAC_SECRET=your_hmac_secret_here

# Database encryption key (for enterprise)
AEGISGATE_DB_ENCRYPTION_KEY=your_encryption_key_here