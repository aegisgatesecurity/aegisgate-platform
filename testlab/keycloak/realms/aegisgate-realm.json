{
  "id": "aegisgate",
  "realm": "aegisgate",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "bruteForceProtected": false,
  "roles": {
    "realm": [
      { "name": "admin", "description": "Administrator role" },
      { "name": "operator", "description": "Operator role" },
      { "name": "developer", "description": "Developer role" },
      { "name": "viewer", "description": "Viewer role" }
    ]
  },
  "clients": [
    {
      "clientId": "aegisgate-platform",
      "enabled": true,
      "publicClient": false,
      "bearerOnly": false,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true,
      "protocol": "openid-connect",
      "redirectUris": ["http://localhost:8443/*", "http://localhost:8080/*"],
      "webOrigins": ["*"],
      "attributes": {
        "access.token.lifespan": "300",
        "client.secret.creation.time": "1714000000"
      },
      "secret": "aegisgate-oidc-secret"
    },
    {
      "clientId": "aegisgate-platform-saml",
      "enabled": true,
      "clientId": "aegisgate-saml",
      "name": "AegisGate SAML Client",
      "description": "SAML 2.0 client for AegisGate",
      "protocol": "saml",
      "redirectUris": ["http://localhost:8443/sso/saml/callback"],
      "baseUrl": "http://localhost:8443",
      "enabled": true,
      "alwaysDisplayInConsole": false,
      "clientAuthenticatorType": "client-secret-jwt",
      "secret": "aegisgate-saml-secret",
      "attributes": {
        "saml.client.signature": "true",
        "saml.signing.certificate": "",
        "saml.artifact.resolution.endpoint": "http://localhost:8080/realms/aegisgate/protocol/saml/artefact",
        "saml_assertion_consumer_service_url": "http://localhost:8443/sso/saml/callback",
        "saml_single_logout_service_url": "http://localhost:8443/sso/saml/logout",
        "saml_name_id_format": "email",
        "saml_force_name_id_format": "false",
        "saml.client.signature": "true"
      },
      "defaultClientScopes": ["web-origins", "profile", "roles", "email"],
      "optionalClientScopes": ["address", "phone", "offline_access", "microprofile-jwt"]
    },
    {
      "clientId": "aegisgate-mcp",
      "enabled": true,
      "publicClient": true,
      "bearerOnly": false,
      "standardFlowEnabled": false,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "protocol": "openid-connect",
      "redirectUris": ["http://localhost:9090/*"],
      "webOrigins": ["*"],
      "attributes": {
        "access.token.lifespan": "3600"
      }
    }
  ],
  "users": [
    {
      "username": "admin",
      "enabled": true,
      "emailVerified": true,
      "email": "admin@aegisgate.local",
      "firstName": "Admin",
      "lastName": "User",
      "credentials": [
        { "type": "password", "value": "admin", "temporary": false }
      ],
      "realmRoles": ["admin"]
    },
    {
      "username": "operator",
      "enabled": true,
      "emailVerified": true,
      "email": "operator@aegisgate.local",
      "firstName": "Operator",
      "lastName": "User",
      "credentials": [
        { "type": "password", "value": "operator", "temporary": false }
      ],
      "realmRoles": ["operator"]
    },
    {
      "username": "developer",
      "enabled": true,
      "emailVerified": true,
      "email": "developer@aegisgate.local",
      "firstName": "Developer",
      "lastName": "User",
      "credentials": [
        { "type": "password", "value": "developer", "temporary": false }
      ],
      "realmRoles": ["developer"]
    },
    {
      "username": "viewer",
      "enabled": true,
      "emailVerified": true,
      "email": "viewer@aegisgate.local",
      "firstName": "Viewer",
      "lastName": "User",
      "credentials": [
        { "type": "password", "value": "viewer", "temporary": false }
      ],
      "realmRoles": ["viewer"]
    }
  ]
}
